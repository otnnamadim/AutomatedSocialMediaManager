# MODULE 4: COLLABORATIVE PRODUCTION & EDITING ENGINE
# =====================================================================
class ProductionEngine:
    """Manages multi-LLM copywriting, image prompting, and collaborative editing."""

    @staticmethod
    def generate_initial_draft(research_brief: str, storyboard: str, voice_examples: list) -> str:
        print("🤖 Crafting initial content drafts (OpenAI)...")
        voice_block = StrategyEngine._format_voice_examples(voice_examples)
        prompt = f"""
        Using this STORYBOARD:
        {storyboard}

        And this RESEARCH BRIEF:
        {research_brief}

        VOICE EXAMPLES TO MATCH: {voice_block}

        Generate a complete 5-day social media plan. Follow this exact template for EACH day:
        ---
        [DAY]:
        [NARRATIVE PURPOSE]:
        [DRAFT COPY]: (Under 280 characters for X)
        ---
        Apply these rules: {SHARED_VOICE_AND_VERIFICATION}
        """
        return openai_generate_with_fallback(prompt)

    @staticmethod
    def collaborative_edit_loop(initial_draft: str, voice_examples: list) -> str:
        print("🪶 Running editor loop (Claude Reviewing OpenAI Draft)...")
        voice_block = StrategyEngine._format_voice_examples(voice_examples)

        editing_prompt = f"""
        Review and ruthlessly polish the following initial social media draft.
        You must enforce these constraints flawlessly:
        {SHARED_VOICE_AND_VERIFICATION}

        VOICE EXAMPLES TO MATCH (rhythm, sentence length, structure): {voice_block}

        INITIAL DRAFT:
        {initial_draft}

        Provide the finalized, edited version of the 5-day plan. Ensure no preambles remain. Keep characters under hard limits.
        """
        message = claude_client.messages.create(
            model=CLAUDE_MODEL,
            max_tokens=5500,
            thinking={"type": "disabled"},
            messages=[{"role": "user", "content": editing_prompt}],
        )
        return message.content[0].text

    @staticmethod
    def self_critique_pass(edited_copy: str, voice_examples: list) -> dict:
        """Extra revision pass: score the edited copy against explicit criteria
        and revise anything that fails. Returns structured JSON so the clean,
        publishable copy is never mixed with scorecards or verification notes —
        those get surfaced separately instead of getting baked into the text
        that downstream steps (or you, when posting) would otherwise use as-is.
        """
        print("🔎 Running self-critique / revision pass (Claude)...")
        voice_block = StrategyEngine._format_voice_examples(voice_examples)

        critique_prompt = f"""
        Score the following finalized social media copy against these criteria,
        one entry per day, PASS or FAIL with a one-sentence reason:
        1. Sounds like the voice examples below (rhythm, sentence length), not generic AI copy.
        2. Leads with the insight in the first sentence — no preamble or hedge.
        3. Every factual claim is either grounded in the research brief or flagged as needing verification.
        4. Fits the platform's hard character limit.

        VOICE EXAMPLES: {voice_block}

        COPY TO SCORE:
        {edited_copy}

        For any day that fails a criterion, revise it. IMPORTANT: the revised
        copy must be publish-ready as-is — do NOT embed verification notes,
        parentheticals, or asterisked caveats inside the copy text itself.
        If a claim can't be grounded, either remove/soften it into an opinion
        statement, or replace it with a claim you ARE confident is accurate
        framing (not a specific stat) — then separately list what needs a
        source check in "flagged_claims", NOT inside the copy.

        Return ONLY valid JSON, no prose outside the JSON, in this exact structure:
        {{
          "days": [
            {{
              "day": 1,
              "clean_copy": "the final publish-ready copy for this day, no caveats or notes embedded",
              "scorecard": {{"voice": "PASS/FAIL", "leads_with_insight": "PASS/FAIL", "claims_grounded": "PASS/FAIL", "char_limit": "PASS/FAIL"}},
              "flagged_claims": ["any claim that still needs a source check before publishing, or empty list"]
            }}
          ],
          "outstanding_notes": "anything the user should address before the next batch (e.g. missing voice examples)"
        }}
        """
        message = claude_client.messages.create(
            model=CLAUDE_MODEL,
            max_tokens=5500,
            thinking={"type": "disabled"},
            messages=[{"role": "user", "content": critique_prompt}],
        )
        raw_text = message.content[0].text.strip()
        # Defensive: strip accidental markdown fences if the model adds them
        if raw_text.startswith("```"):
            raw_text = raw_text.split("```")[1]
            if raw_text.startswith("json"):
                raw_text = raw_text[4:]
            raw_text = raw_text.strip()
        return json.loads(raw_text)

    @staticmethod
    def generate_graphic_prompts(clean_copy_by_day: str) -> str:
        print("🎨 Generating asset visual direction and graphic design prompts...")
        prompt = f"""
        Based on the following approved social copy, generate text-to-image prompts or text-overlay templates for standard graphic design software (Midjourney/Canva/DALL-E).
        Provide a visual prompt/direction for each day that matches a clean, premium brand aesthetic for Black professionals and creatives.

        APPROVED COPY:
        {clean_copy_by_day}
        """
        return openai_generate_with_fallback(prompt)


