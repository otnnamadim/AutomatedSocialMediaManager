class ResearchEngine:
    """Generates clean, transferable research inputs mapping directly to the narrative arc."""

    @staticmethod
    def generate_research_brief(topic: str, weekly_storyboard: str) -> str:
        print("📚 Executing deep research briefing via Claude...")

        prompt = f"""
        You are a specialized content researcher. Prepare a highly transferable research briefing on: {topic}
        It must seamlessly feed into this planned weekly narrative arc:
        {weekly_storyboard}

        Provide structural research items formatted EXACTLY below:
        1. Core Data Points & Verifiable Numbers (Anonymized case studies, dates, real metrics)
        2. Underlying Technical Mechanics (How it works fundamentally)
        3. Clear Human-Interest Hooks (Why a professional or creative stops scrolling)
        4. Risks, Pitfalls, & Hidden Realities
        5. The Strategic Counterpoint (What everyone gets wrong about this topic)
        """

        message = claude_client.messages.create(
            model=CLAUDE_MODEL,
            max_tokens=4000,
            thinking={"type": "disabled"},
            messages=[{"role": "user", "content": prompt}],
        )
        return message.content[0].text


