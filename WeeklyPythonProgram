def openai_generate_with_fallback(prompt: str) -> str:
    """Try OPENAI_MODEL first; on a rate-limit/quota (429) or server (5xx)
    error, fall through to each model in OPENAI_FALLBACK_MODELS in order
    instead of letting the whole pipeline crash."""
    models_to_try = [OPENAI_MODEL] + OPENAI_FALLBACK_MODELS
    last_error = None
    for model_name in models_to_try:
        try:
            response = openai_client.responses.create(model=model_name, input=prompt)
            return response.output_text
        except (RateLimitError, APIStatusError) as e:
            print(f"⚠️ {model_name} unavailable ({e}). Trying next fallback model...")
            last_error = e
            continue
    raise last_error

