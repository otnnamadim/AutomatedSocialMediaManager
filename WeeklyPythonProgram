class StrategyEngine:
    """Establishes the macro strategy and cohesive storyboards across content pillars."""

    # NOTE: Replace the empty voice_examples lists below with 3-5 of your own
    # past posts that you consider genuinely on-voice. Adjectives like "direct"
    # or "data-grounded" carry almost no signal to an LLM — verbatim examples
    # of sentence rhythm and structure do. This is the single highest-leverage
    # change you can make to output quality.
    BRAND_CONFIG = {
        "ozoemena_nnamadim": {
            "display_name": "Ozoemena Nnamadim",
            "voice": "personal, professional, direct, data-grounded, and skeptical of hype",
            "voice_examples": [
                # "Paste 3-5 of your own past posts here, verbatim, that you consider your best voice.",
            ],
            "pillars": [
                "Learned Experiences from Founding a Startup",
                "CPA Pipeline Content",
                "Economic Policy Content",
                "Application of Auditing Knowledge in Various Areas of Life",
                "General Healthy, Black, LGBTQ, Professional Lifestyle Content",
            ],
            "formats": ["plain_text", "thread"],
        },
        "aperture_advisory": {
            "display_name": "Aperture Advisory",
            "voice": "focused on building brand awareness through consistent demonstrations of complex analysis and thought leadership in public accounting, economic policy, and technological innovation",
            "voice_examples": [
                # "Paste 3-5 of your own past posts here, verbatim, that you consider your best voice.",
            ],
            "pillars": [
                "Application of Technology in Small Business",
                "Technical Analysis of Trends in Financial Markets & Economic Policy",
                "Process Improvement due to AI",
            ],
            "formats": ["aperture_card", "plain_text", "thread"],
        },
    }



    @staticmethod
    def _format_voice_examples(examples: list) -> str:
        if not examples:
            return "(No verbatim examples provided yet — relying on the voice description only, which is weaker. Add real past posts to BRAND_CONFIG for stronger voice matching.)"
        numbered = "\n".join(f"{i+1}. {ex}" for i, ex in enumerate(examples))
        return f"Match the rhythm, sentence length, and structure of these actual past posts:\n{numbered}"

    @staticmethod
    def generate_weekly_storyboard(brand_key: str, monthly_theme: str, active_pillar: str,
                                   performance_data: dict, weekly_target: dict = None) -> str:
        brand = StrategyEngine.BRAND_CONFIG[brand_key]
        print(f"🎯 Creating a cohesive weekly storyboard for {brand['display_name']} — Pillar: {active_pillar}...")

        voice_block = StrategyEngine._format_voice_examples(brand["voice_examples"])
        perf_summary = performance_data.get("summary", str(performance_data))

        target_block = ""
        if weekly_target:
            target_block = (
                    f"WEEKLY TARGET (from plan-vs-actual tracker, week of {weekly_target['week']}): "
                    f"~{weekly_target['impressions']} impressions"
                    + (f", ~{weekly_target['likes']} likes" if weekly_target['likes'] else "")
                    + ". Set cadence and format ambition consistent with reaching this target."
            )

        prompt = f"""
            You are the content strategist for {brand['display_name']}, a brand founded
            and developed by a CPA focused on re-establishing credibility and
            documenting hands-on Python/fintech experimentation. Both this brand and
            its sibling brand correct popular narratives with real, factual data rather
            than anecdotes or speculation.

            BRAND VOICE (description): {brand['voice']}
            BRAND VOICE (examples): {voice_block}
            AVAILABLE FORMATS: {', '.join(brand['formats'])}
            ALL PILLARS FOR THIS BRAND: {', '.join(brand['pillars'])}

            MONTHLY THEME: {monthly_theme}
            ACTIVE PILLAR (this week's focus): {active_pillar}
            PERFORMANCE ANALYSIS (already computed, treat as ground truth): {perf_summary}
            {target_block}

            Define a cohesive 5-day story arc (throughline) for this week's content,
            built around the active pillar above, using only the formats listed for
            this brand.

            Before drafting, briefly note how the performance analysis above should
            shape format/angle choices this week — 1-2 sentences, in a
            "performance_notes" field.

            For each day, choose the narrative beat that best fits this week's topic —
            don't force a beat (e.g., a contrarian take) if the topic has no genuine
            tension to explore. If a beat doesn't fit, replace it with a stronger one
            and say why in "beat_rationale".

            Standard beats to draw from (use, skip, or reorder as the topic demands):
            Hook/Problem, Data/Evidence, Solution/Framework, Contrarian Take,
            Actionable Summary.

            If a day's draft relies on a specific statistic, market figure, or claim
            that isn't already provided in the performance data or theme inputs, flag
            it explicitly in "needs_verification" rather than stating it as fact.

            Return ONLY valid JSON in this exact structure, no prose outside the JSON:

            {{
              "brand": "{brand['display_name']}",
              "active_pillar": "{active_pillar}",
              "weekly_throughline": "one sentence connecting all 5 days",
              "performance_notes": "1-2 sentences on how performance data shaped this plan",
              "days": [
                {{
                  "day": 1,
                  "beat": "name of narrative beat used",
                  "beat_rationale": "why this beat fits (only if it deviates from standard)",
                  "format": "one of the brand's available formats",
                  "concept": "2-3 sentence description of the post's content",
                  "needs_verification": ["any claims requiring a source check, or empty list"]
                }}
              ]
            }}
            """
        return openai_generate_with_fallback(prompt)


