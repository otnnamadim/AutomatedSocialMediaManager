import tweepy
import datetime

def get_current_week_target(plan_csv=Path(__file__).parent / "output" / "weekly_plan_vs_actual.csv"):
    """This calendar week's planned targets from the plan CSV, so the storyboard
    is held to a number. Returns None if the file is missing or the week is past
    the planned horizon."""
    try:
        plan = pd.read_csv(plan_csv)
    except FileNotFoundError:
        return None
    week_start = pd.Timestamp(datetime.date.today()).to_period("W-SAT").start_time  # Sunday
    label = week_start.strftime("%-m/%-d/%Y")  # macOS/Linux; use %#m/%#d on Windows
    row = plan.loc[plan["Week"] == label]
    if row.empty or pd.isna(row.iloc[0].get("Impressions (Planned)")):
        return None
    r = row.iloc[0]
    return {
        "week": label,
        "impressions": int(r["Impressions (Planned)"]),
        "likes": int(r["Likes (Planned)"]) if pd.notna(r.get("Likes (Planned)")) else None,
    }

class AnalyticsEngine:
    """Connects to X API v2, fetches recent tweets, and computes actual
    engagement statistics + structural features in Python (not in the prompt).
    The LLM receives conclusions, not raw numbers, so it isn't asked to do
    statistical inference in its head."""

    FALLBACK = {
        "live_data_active": False,
        "summary": (
            "Static baseline from CSV export through 2026-06-17 (38 posts): "
            "typical organic post ~80 impressions; like rate 1.3%, reply and "
            "repost rates ~0.1% per impression. All four outlier posts "
            "(1.7K-46K impressions) were data-driven/contrarian takes, while "
            "the organic floor is low-engagement — consistency, not volume, "
            "is the current gap."
        ),
        "top_features": ["specific_number_in_first_sentence", "contrarian_opener"],
        "avoid_features": ["generic_motivational_language"],
    }

    @staticmethod
    def _extract_features(text: str) -> dict:
        """Cheap, deterministic structural features computed in code."""
        stripped = text.strip()
        return {
            "char_count": len(stripped),
            "word_count": len(stripped.split()),
            "opens_with_question": stripped.rstrip().endswith("?") is False and stripped.split("\n")[0].strip().endswith("?"),
            "has_number": any(ch.isdigit() for ch in stripped[:60]),
            "is_thread_like": "\n" in stripped or stripped.count(".") > 4,
        }

    @staticmethod
    def get_recent_performance_data() -> dict:
        print("📊 Extracting live analytics from your X account...")

        if not X_BEARER_TOKEN or not X_API_KEY:
            print("⚠️ X API keys missing or incomplete. Using fallback data.")
            return AnalyticsEngine.FALLBACK

        try:
            client = tweepy.Client(
                bearer_token=X_BEARER_TOKEN,
                consumer_key=X_API_KEY,
                consumer_secret=X_API_SECRET,
                access_token=X_ACCESS_TOKEN,
                access_token_secret=X_ACCESS_SECRET
            )

            me = client.get_me()
            user_id = me.data.id
            username = me.data.username
            print(f"🔗 Authenticated successfully as @{username} (ID: {user_id})")

            # Pull more history than before — 5 data points isn't enough to
            # separate signal from noise. 30-50 gives quartiles something to work with.
            tweets = client.get_users_tweets(
                id=user_id,
                max_results=50,
                tweet_fields=["public_metrics", "text", "created_at"]
            )

            if not tweets.data:
                print("⚠️ No tweets returned. Using fallback data.")
                return AnalyticsEngine.FALLBACK

            rows = []
            for tweet in tweets.data:
                m = tweet.public_metrics
                impressions = m.get("impression_count", 0) or 1  # avoid div by zero
                engagement = m.get("like_count", 0) + m.get("retweet_count", 0) + m.get("reply_count", 0)
                rate = engagement / impressions
                features = AnalyticsEngine._extract_features(tweet.text)
                rows.append({
                    "text": tweet.text,
                    "engagement_rate": rate,
                    "raw_engagement": engagement,
                    "impressions": impressions,
                    **features
                })

            # Rank by engagement rate, not raw counts (raw counts are biased
            # toward whatever got the most impressions, not what resonated).
            rows.sort(key=lambda r: r["engagement_rate"], reverse=True)
            n = len(rows)
            top_cut = max(1, n // 4)
            top_quartile = rows[:top_cut]
            bottom_quartile = rows[-top_cut:]

            def summarize(group, label):
                avg_words = statistics.mean(r["word_count"] for r in group)
                pct_number = sum(r["has_number"] for r in group) / len(group) * 100
                pct_question = sum(r["opens_with_question"] for r in group) / len(group) * 100
                pct_thread = sum(r["is_thread_like"] for r in group) / len(group) * 100
                return (
                    f"{label} (n={len(group)}): avg {avg_words:.0f} words, "
                    f"{pct_number:.0f}% include a concrete number early, "
                    f"{pct_question:.0f}% open with a question, "
                    f"{pct_thread:.0f}% are thread-like/multi-sentence."
                )

            top_summary = summarize(top_quartile, "TOP QUARTILE (by engagement rate)")
            bottom_summary = summarize(bottom_quartile, "BOTTOM QUARTILE (by engagement rate)")

            # Give the LLM 2-3 verbatim top examples as pattern references,
            # not just stats — this is what actually transfers "what worked."
            top_examples = [r["text"] for r in top_quartile[:3]]

            return {
                "live_data_active": True,
                "sample_size": n,
                "top_quartile_summary": top_summary,
                "bottom_quartile_summary": bottom_summary,
                "top_performing_examples": top_examples,
                "summary": (
                    f"{top_summary} {bottom_summary} "
                    "Favor structural patterns from the top quartile; avoid patterns "
                    "concentrated in the bottom quartile."
                ),
            }

        except Exception as e:
            print(f"❌ X API Error: {e}. Defaulting to strategic fallback configuration.")
            fallback = dict(AnalyticsEngine.FALLBACK)
            fallback["api_error_log"] = str(e)
            return fallback


