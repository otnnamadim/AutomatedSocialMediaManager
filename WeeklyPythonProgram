if __name__ == "__main__":
    # Each brand gets its own monthly theme, since they're different audiences
    # with different goals rather than one shared narrative.
    MONTHLY_THEMES = {
        "ozoemena_nnamadim": "Rebuilding and Career Pivots",
        "aperture_advisory": "Technology Integration for Small and Medium Enterprises",
    }

    print("🚀 STARTING ENTERPRISE WORKFLOW — FULL CONTENT CALENDAR (ALL PILLARS)")

    # 1. Analytics & Feedback Loop (shared across both brands, computed once
    #    per run rather than once per pillar — the account's performance
    #    history doesn't change between pillars in the same run).
    analytics = AnalyticsEngine.get_recent_performance_data()
    weekly_target = get_current_week_target()

    # 2. Outer loop: each brand
    for brand_key, brand_cfg in StrategyEngine.BRAND_CONFIG.items():
        monthly_theme = MONTHLY_THEMES[brand_key]
        print(f"\n{'='*70}\n BRAND: {brand_key}  |  THEME: {monthly_theme}\n{'='*70}")

        # 3. Inner loop: every pillar for this brand gets its own full 5-day
        #    storyboard, instead of picking a single ACTIVE_PILLAR — this is
        #    what turns the run into a complete weekly content calendar
        #    (serious/technical + lifestyle + all other pillars together).
        for pillar_idx, pillar in enumerate(brand_cfg["pillars"], start=1):
            print(f"\n{'-'*70}\n PILLAR {pillar_idx}/{len(brand_cfg['pillars'])}: {pillar}\n{'-'*70}")

            # Strategy & Storyboard Development
            weekly_storyboard = StrategyEngine.generate_weekly_storyboard(
                brand_key, monthly_theme, pillar, analytics, weekly_target
            )
            print(f"\n🗺️ WEEKLY STORYBOARD MAP ({brand_key} / {pillar}):\n", weekly_storyboard)

            # Transferable Research Collection
            research_brief = ResearchEngine.generate_research_brief(pillar, weekly_storyboard)

            # Content Production & Multi-LLM Review Loop (voice-example aware)
            raw_draft = ProductionEngine.generate_initial_draft(
                research_brief, weekly_storyboard, brand_cfg["voice_examples"]
            )
            edited_copy = ProductionEngine.collaborative_edit_loop(
                raw_draft, brand_cfg["voice_examples"]
            )
            critique_result = ProductionEngine.self_critique_pass(
                edited_copy, brand_cfg["voice_examples"]
            )

            # Build the clean, publish-ready copy (no scorecards or verification
            # notes embedded) — this is the only version that gets used downstream
            # or that you should copy/paste into a scheduler.
            clean_copy_lines = []
            flags_found = False
            for day in critique_result["days"]:
                clean_copy_lines.append(f"--- Day {day['day']} ---\n{day['clean_copy']}\n")
                if day.get("flagged_claims"):
                    flags_found = True
            clean_copy_text = "\n".join(clean_copy_lines)

            print(f"\n✨ FINAL COPY FOR YOUR APPROVAL ({brand_key} / {pillar}) — publish-ready:\n{clean_copy_text}")

            # Surface anything needing a source check separately, instead of
            # burying it inside the copy itself.
            if flags_found:
                print(f"\n⚠️ CLAIMS FLAGGED FOR VERIFICATION ({brand_key} / {pillar}) — confirm before posting:")
                for day in critique_result["days"]:
                    if day.get("flagged_claims"):
                        print(f"  Day {day['day']}: {day['flagged_claims']}")
            if critique_result.get("outstanding_notes"):
                print(f"\n📝 Outstanding notes ({brand_key} / {pillar}): {critique_result['outstanding_notes']}")

            # Asset Prompt Production (Graphic/Image Engine)
            design_brief = ProductionEngine.generate_graphic_prompts(clean_copy_text)
            print(f"\n🎨 COMPANION VISUAL DESIGN PROMPTS ({brand_key} / {pillar}):\n", design_brief)

    print(f"\n{'='*70}")
    print("🎬 FULL CONTENT CALENDAR COMPLETE FOR ALL BRANDS & PILLARS")
    print(f"{'='*70}")
    for brand_key, brand_cfg in StrategyEngine.BRAND_CONFIG.items():
        n_pillars = len(brand_cfg["pillars"])
        print(f"  • {brand_cfg['display_name']}: {n_pillars} pillars × 5 days = {n_pillars * 5} posts")
    print("\nReady for manual staging, fact-checking, and scheduling.")
